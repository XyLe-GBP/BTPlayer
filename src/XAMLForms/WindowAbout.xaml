<Window x:Class="BTPlayer.WindowAbout"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BTPlayer"
        mc:Ignorable="d"
        Title="About BlueTooth audio Player" Height="650" Width="650" Loaded="Grid_Loaded" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" SizeToContent="WidthAndHeight" ShowInTaskbar="False">
    <Grid Loaded="Grid_Loaded">
        <Grid.Background>
            <ImageBrush ImageSource="/Properties/BTPlayer_icon.png" Opacity="0.15" Stretch="UniformToFill" />
        </Grid.Background>
        <Image x:Name="Image_GitHub" HorizontalAlignment="Left" Height="200" Margin="28,270,0,0" VerticalAlignment="Top" Width="200" Source="/Properties/BTPlayer_icon.png" RenderTransformOrigin="0,0">
            <Image.Clip>
                <EllipseGeometry RadiusX="100" RadiusY="100" Center="100,100" />
            </Image.Clip>
        </Image>
        <TextBlock HorizontalAlignment="Center" Margin="0,70,0,0" TextWrapping="Wrap" Text="BTPlayer&#xa;Play audio via Bluetooth A2DP Sink(SNK) on Windows." VerticalAlignment="Top" Height="65" Width="600" TextAlignment="Center" FontSize="23" FontWeight="Bold"/>
        <TextBlock HorizontalAlignment="Center" Margin="0,190,0,0" TextWrapping="Wrap" Text="Copyright © 2026 - XyLe. All Rights Reserved." VerticalAlignment="Top" Height="20" Width="630" TextAlignment="Center" FontSize="14"/>
        <Label HorizontalAlignment="Left" Margin="290,355,0,0" VerticalAlignment="Top" FontSize="24">
            <Hyperlink Name="HL_GitHub" NavigateUri="https://github.com/XyLe-GBP" RequestNavigate="HL_GitHub_RequestNavigate">My GitHub</Hyperlink>
        </Label>
        <Label HorizontalAlignment="Left" Margin="470,355,0,0" VerticalAlignment="Top" FontSize="24">
            <Hyperlink Name="HL_Website" NavigateUri="https://xyle-official.com" RequestNavigate="HL_Website_RequestNavigate">My Website</Hyperlink>
        </Label>
        <Label HorizontalAlignment="Left" Margin="410,485,0,0" VerticalAlignment="Top" FontSize="24">
            <Hyperlink Name="HL_Donate" NavigateUri="https://secure.xyle-official.com/payment/donate" RequestNavigate="HL_Donate_RequestNavigate">Donation page</Hyperlink>
        </Label>
        <TextBlock HorizontalAlignment="Left" Margin="10,495,0,0" TextWrapping="Wrap" Text="If you like this app, buy me a beer." VerticalAlignment="Top" Height="25" Width="385" FontSize="18" TextAlignment="Center"/>
        <Button x:Name="Button_OK" Content="Done!" HorizontalAlignment="Left" Margin="565,580,0,0" VerticalAlignment="Top" Width="75" Height="40" FontSize="20" Click="Button_OK_Click"/>
    </Grid>
</Window>
